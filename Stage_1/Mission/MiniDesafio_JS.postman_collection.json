        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El código de estado es 404\"), function () {",
              "    pm.response.to.have.status(404);",
              "};",
              "",
              "",
              "pm.test(\"mensaje de error no fount\"), function () {",
              "    const jsonData = pm.response.json();",
              "",
              "    pm.expect(jsonData).to.have.property(\"error\")",
              "    pm.expect(jsonData.error).to.eql(\"Character not found\")",
              "}",
              "",
              "pm.test(\"Retornar el id enviado\"), function () {",
              "",
              "    const jsonData = pm.response.json();",
              "    const sentId = parseInt(pm.environment.get(\"invalid_character_id\"))",
              "",
              "    pm.expect(jsonData.id).to.eql(sentId);",
              "}",
              "",
              "",
              "pm.test(\"El mensaje de error es 'Invalid page parameter\"), function () {",
              "",
              "    const jsonData = pm.response.json();",
              "",
              "    pm.expect(jsonData.error).to.eql(\"Invalid page parameter\");",
              "",
              "};",
              "",
              "pm.test(\"Results\", function () {",
              "",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.not.have.property(\"results\");",
              "",
              "});",
              "",
              "",
              "",
