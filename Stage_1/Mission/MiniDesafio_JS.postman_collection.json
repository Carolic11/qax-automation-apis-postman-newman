  "item": [
    {
      "name": "MiniDesa_typicode_characters",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "pm.test(\"El código de estado es 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"El header contiene Content-Type\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});",
              "",
              "pm.test(\"Validar la estructura correcta root\", function () {",
              "    const jsonData = pm.response.json();",
              "",
              "    pm.expect(jsonData).to.be.an(\"object\");",
              "    pm.expect(jsonData).to.have.property(\"count\");",
              "    pm.expect(jsonData).to.have.property(\"next\");",
              "    pm.expect(jsonData).to.have.property(\"prev\");",
              "    pm.expect(jsonData).to.have.property(\"pages\");",
              "    pm.expect(jsonData).to.have.property(\"results\");",
              "});",
              "",
              "pm.test(\"Validar tipos de datos del root\", function () {",
              "    const jsonData = pm.response.json();",
              "",
              "    pm.expect(jsonData.count).to.be.a(\"number\");",
              "    pm.expect(jsonData.pages).to.be.a(\"number\");",
              "",
              "    // next / prev pueden venir como null o string (URL)",
              "    pm.expect(jsonData.next === null || typeof jsonData.next === \"string\").to.be.true;",
              "    pm.expect(jsonData.prev === null || typeof jsonData.prev === \"string\").to.be.true;",
              "",
              "    pm.expect(jsonData.results).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Validar count > 0\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.count).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Pages es mayor que 0\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.pages).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Pages <= expectedPages\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.pages).to.be.at.most(200);",
              "});",
              "",
              "pm.test(\"Validar la cantidad de elementos (results) es mayor que 0\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.results.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Validar estructura y tipos de datos de personajes\", function () {",
              "    const jsonData = pm.response.json();",
              "",
              "    pm.expect(jsonData.results).to.be.an(\"array\");",
              "",
              "    jsonData.results.forEach((c) => {",
              "        // estructura",
              "        pm.expect(c).to.be.an(\"object\");",
              "        pm.expect(c).to.have.property(\"id\");",
              "        pm.expect(c).to.have.property(\"name\");",
              "        pm.expect(c).to.have.property(\"age\");",
              "        pm.expect(c).to.have.property(\"gender\");",
              "        pm.expect(c).to.have.property(\"occupation\");",
              "        pm.expect(c).to.have.property(\"portrait_path\");",
              "        pm.expect(c).to.have.property(\"phrases\");",
              "        pm.expect(c).to.have.property(\"status\");",
              "        pm.expect(c).to.have.property(\"birthdate\");",
              "",
              "        // tipos",
              "        pm.expect(c.id).to.be.a(\"number\");",
              "        pm.expect(c.name).to.be.a(\"string\");",
              "",
              "        // age puede ser number o null",
              "        pm.expect(c.age === null || typeof c.age === \"number\").to.be.true;",
              "",
              "        pm.expect(c.gender).to.be.a(\"string\");",
              "        pm.expect(c.occupation).to.be.a(\"string\");",
              "        pm.expect(c.portrait_path).to.be.a(\"string\");",
              "        pm.expect(c.status).to.be.a(\"string\");",
              "",
              "        // birthdate puede ser null o string",
              "        pm.expect(c.birthdate === null || typeof c.birthdate === \"string\").to.be.true;",
              "",
              "    ",
              "        pm.expect(c.phrases).to.be.an(\"array\");",
              "        c.phrases.forEach((p) => pm.expect(p).to.be.a(\"string\"));",
              "    });",
              "",
              "",
              "});",
              "",
              "pm.test(\"Listado ordenado por id ascendente\", function () {",
              "    const jsonData = pm.response.json();",
              "    const results = jsonData.results;",
              "",
              "    for (let i = 0; i < results.length - 1; i++) {",
              "        pm.expect(results[i].id).to.be.at.most(results[i + 1].id);",
              "    }",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
